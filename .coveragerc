[run]
source = custom_components/navien_navilink_wh
omit =
    # MQTT-over-WebSocket transport: paho socket-pump / live-broker bound.
    # Validated end-to-end against the live NaviLink broker, not in unit tests.
    custom_components/navien_navilink_wh/navilink/transport.py

[report]
exclude_also =
    if TYPE_CHECKING:
    raise NotImplementedError
